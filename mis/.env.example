# ====================================================================
# VARIABLES DE ENTORNO - PLANTILLA
# ====================================================================
# Copiar este archivo a .env y llenar con tus valores
# 
# Para desarrollo con Docker: NO necesitas este archivo
# Para producción: SÍ necesitas este archivo con valores seguros
# 
# Uso: docker run --env-file .env mi-aplicacion
# ====================================================================

# ====================================================================
# BASE DE DATOS - Producción
# ====================================================================
DB_URL=jdbc:postgresql://servidor-produccion:5432/schedulingdb
DB_USERNAME=postgres_user
DB_PASSWORD=contraseña_muy_segura_aqui

# ====================================================================
# SEGURIDAD - JWT
# ====================================================================
# Generar con: openssl rand -hex 32
JWT_SECRET=clave_jwt_de_minimo_32_caracteres_generada_con_openssl

# ====================================================================
# SPRING BOOT PROFILES
# ====================================================================
SPRING_PROFILES_ACTIVE=production

# ====================================================================
# SERVIDOR
# ====================================================================
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# ====================================================================
# LOGGING
# ====================================================================
LOGGING_LEVEL_COM_MIS_MIS=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=WARN
LOGGING_FILE_NAME=/var/log/scheduling-system/application.log

# ====================================================================
# VALIDACIONES PERSONALIZADAS
# ====================================================================
APP_LATENESS_TOLERANCE_MINUTES=5
APP_MAX_WORK_HOURS_PER_DAY=12

# ====================================================================
# NOTAS IMPORTANTES
# ====================================================================
# 
# Para Desarrollo (Docker):
# - Usar docker-compose.yml (ya tiene valores)
# - NO necesitas variables de entorno
# - Las credenciales están en docker-compose.yml
#
# Para Producción:
# - Copiar a .env
# - Cambiar valores con los de tu entorno
# - NUNCA commitear .env a Git
# - Agregar .env a .gitignore
# - Usar un secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# Generación de JWT_SECRET:
# Linux/Mac: openssl rand -hex 32
# PowerShell: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#
# ====================================================================
